{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FuSa Markdown Front Matter Metadata",
  "type": "object",
  "required": [
    "doc_id",
    "title",
    "work_product_type",
    "iso_ref",
    "asil",
    "status",
    "owner",
    "version",
    "last_updated"
  ],
  "properties": {
    "doc_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "work_product_type": {
      "type": "string",
      "enum": [
        "generic",
        "item-definition",
        "hara",
        "fsc",
        "tsc",
        "safety-requirements",
        "verification-validation",
        "safety-case"
      ]
    },
    "iso_ref": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "asil": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "Draft",
        "In Review",
        "Approved",
        "Obsolete",
        "待定"
      ]
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "reviewers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+$"
    },
    "baseline": {
      "type": "string"
    },
    "last_updated": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    }
  },
  "additionalProperties": true
}
