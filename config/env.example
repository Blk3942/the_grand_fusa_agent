# 复制本文件为项目根目录下的 .env 并填写（.env 已被 .gitignore 忽略）
# 请勿将真实密钥提交到 Git

# 示例：OpenAI 兼容接口
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1

# 示例：Anthropic
# ANTHROPIC_API_KEY=

# 示例：Azure OpenAI
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_DEPLOYMENT=

# 应用
# LOG_LEVEL=INFO
